{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://aah.spec/schemas/section.schema.json",
  "title": "AAH Section",
  "description": "A section within an AAH artifact (v0.5)",
  "type": "object",
  "required": ["id", "heading", "type", "agent_id", "created_at", "updated_at"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Stable section identifier (e.g., 'overview', 'api-schema')",
      "pattern": "^[a-z0-9][a-z0-9-]*$",
      "examples": ["main", "overview", "api-schema", "day-1"]
    },
    "heading": {
      "type": "string",
      "description": "Display title for the section",
      "minLength": 1,
      "maxLength": 200
    },
    "type": {
      "type": "string",
      "description": "Content type in category/subtype format",
      "pattern": "^[a-z]+/[a-z0-9-]+$",
      "examples": ["document/markdown", "code/typescript", "data/csv", "image/png"]
    },
    "body": {
      "type": ["string", "object"],
      "description": "Inline content. String for text/code/data, object for structured/json."
    },
    "body_url": {
      "type": "string",
      "format": "uri",
      "description": "URL to fetch content (for large or binary content)"
    },
    "media_type": {
      "type": "string",
      "description": "MIME type override (derived from type if omitted)"
    },
    "encoding": {
      "type": "string",
      "default": "utf-8",
      "description": "Character encoding"
    },
    "body_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$",
      "description": "SHA-256 hash of content"
    },
    "size_bytes": {
      "type": "integer",
      "minimum": 0,
      "description": "Content size in bytes"
    },
    "token_count": {
      "type": "integer",
      "minimum": 0,
      "description": "Estimated token count for LLM context budgeting"
    },
    "agent_id": {
      "type": "string",
      "description": "Identifier of the agent that owns this section"
    },
    "agent_name": {
      "type": "string",
      "description": "Human-readable name of the agent"
    },
    "position": {
      "type": "integer",
      "description": "Display order (0-indexed)",
      "minimum": 0,
      "default": 0
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of section creation"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of last modification"
    },
    "version": {
      "type": "integer",
      "description": "Section version number",
      "minimum": 1,
      "default": 1
    }
  },
  "anyOf": [
    { "required": ["body"] },
    { "required": ["body_url"] }
  ]
}
